# 选择一种API配置即可

# 方案1: OpenAI API（需翻墙）
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# 方案2: DeepSeek API（推荐，国内可用，便宜）
# OPENAI_API_KEY=sk-your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com/v1

# 方案3: 通义千问 API
# OPENAI_API_KEY=sk-your-qwen-key
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 方案4: 硅基流动（聚合平台，支持多种模型，包括DeepSeek和中文Embedding）
OPENAI_API_KEY=sk-your-qwen-key
OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# LLM 模型选择（使用 SiliconFlow 上的模型，可选 deepseek-ai/DeepSeek-V2.5 或 Qwen/Qwen2.5-7B-Instruct）
LLM_MODEL=Pro/zai-org/GLM-5.1

# Embedding 模型（中文推荐 bge-large-zh-v1.5）
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
